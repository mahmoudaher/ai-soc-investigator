            "user": "service_account",
            "domain": "malicious-site.com",
            "process": "powershell.exe",
        },
        entities=[Entity(type="host", value="workstation-01")],
        timeline=[
            TimelineEvent(
                timestamp=CaseFile.model_fields["created_at"].default_factory(),
                title="Case Created",
